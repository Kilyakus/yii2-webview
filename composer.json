{
    "name": "kilyakus/yii2-webview",
    "description": "Yii2 «WebView» asset bundle.",
    "type": "yii2-extension",
    "keywords": ["yii2", "extension", "webview", "asset"],
    "license": "CC-BY-NC-4.0",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "kilyakus/js-webview": "dev-master",
        "kilyakus/js-scrollview": "dev-master",
        "kilyakus/js-dockview": "dev-master",
        "kilyakus/js-holdview": "dev-master"
    },
    "repositories": [
        {
            "type": "package",
            "package": {
                "name": "kilyakus/js-scrollview",
                "version": "dev-master",
                "source": {
                    "url": "https://github.com/Kilyakus/js-scrollview",
                    "type": "git",
                    "reference": "master"
                }
            }
        },
        {
            "type": "package",
            "package": {
                "name": "kilyakus/js-webview",
                "version": "dev-master",
                "source": {
                    "url": "https://github.com/Kilyakus/js-webview",
                    "type": "git",
                    "reference": "master"
                }
            }
        },
        {
            "type": "package",
            "package": {
                "name": "kilyakus/js-dockview",
                "version": "dev-master",
                "source": {
                    "url": "https://github.com/Kilyakus/js-dockview",
                    "type": "git",
                    "reference": "master"
                }
            }
        },
        {
            "type": "package",
            "package": {
                "name": "kilyakus/js-holdview",
                "version": "dev-master",
                "source": {
                    "url": "https://github.com/Kilyakus/js-holdview",
                    "type": "git",
                    "reference": "master"
                }
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "kilyakus\\webview\\": "src/"
        }
    }
}
